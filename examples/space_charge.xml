<?xml version="1.0"?>
<teufel description="Space charge field of a particle"
    author="Ulf Lehnert 19.2.2019">
    <calc print="gamma = " var="gamma" eq="40.0"/>
    <calc print="beta = " var="beta" eq="sqrt(1.0-1.0/(gamma*gamma))"/>
    <calc print="lambda_R = " var="lambda" eq="1e-4"/>
    <calc print="lambda_U = " var="lambda_U" eq="0.1"/>
    <lattice>
        <undulator name="U300" type="planar">
            <!-- compute undulator setting from desired output frequency -->
            <calc print="K_rms(U300) = " var="K_rms" eq="sqrt(lambda/lambda_U*2*gamma*gamma-1)" />
            <!-- setup the undulator -->
            <field B="K_rms*sqrt(2)/_c*2*_pi*_mec2/lambda_U"
                   period="lambda_U" N="8" />
            <position x="0.0" y="0.0" z="1.0"/>
        </undulator>
    </lattice>
    <beam>
        <bunch gamma="gamma" charge="-1.0e-9" cmr="-1.0" n="100" >
            <position x="0.0" y="0.0" z="0.0" xrms="2.0e-4" zrms="0.2e-4" />
            <momentum x="0.0" y="0.0" z="1.0" delta="0.0" />
        </bunch>
    </beam>
    <calc print="tracking length [m] = " var="total_L" eq="2.5" />
    <calc print="tracking total time [s] = " var="total_t" eq="total_L/beta/_c" />
    <calc print="dt = " var="dt" eq="total_t/5000" />
    <tracking method="Vay" delta_t="dt" n="5000" >
    </tracking>
    <observer>
        <snapshot file="Space_charge_000.h5">
            <calc print="tobs = " var="tobs" eq="0"/>
            <calc print="zobs = " var="zobs" eq="tobs*beta*_c"/>
            <time t0="tobs" />
            <position x="0.0" y="0.0" z="zobs" />
            <hpitch x="0.000010" y="0.0" z="0.0" n="201" />
            <vpitch x="0.0" y="0.0" z="0.000010" n="201" />
        </snapshot>
        <snapshot file="Space_charge_100.h5">
            <calc print="tobs = " var="tobs" eq="2000.0*dt"/>
            <calc print="zobs = " var="zobs" eq="tobs*beta*_c"/>
            <time t0="tobs" />
            <position x="0.0" y="0.0" z="zobs" />
            <hpitch x="0.000002" y="0.0" z="0.0" n="1001" />
            <vpitch x="0.0" y="0.0" z="0.000001" n="601" />
        </snapshot>
        <snapshot file="Space_charge_200.h5">
            <calc print="tobs = " var="tobs" eq="4000.0*dt"/>
            <calc print="zobs = " var="zobs" eq="tobs*beta*_c"/>
            <time t0="tobs" />
            <position x="0.0" y="0.0" z="zobs" />
            <hpitch x="0.000010" y="0.0" z="0.0" n="201" />
            <vpitch x="0.0" y="0.0" z="0.000010" n="201" />
        </snapshot>
    </observer>
</teufel>
